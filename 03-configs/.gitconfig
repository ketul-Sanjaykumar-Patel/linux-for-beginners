# ─────────────────────────────────────────
# .gitconfig — Git config template
# Part of: linux-for-beginners by Ketul Patel
# Usage: cp .gitconfig ~/.gitconfig
# Then update name and email below
# ─────────────────────────────────────────

[user]
    name = Your Full Name
    email = your@email.com

[init]
    defaultBranch = main

[core]
    editor = nano
    autocrlf = input

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit -m
    lg = log --oneline --graph --decorate
    undo = reset --soft HEAD~1
    unstage = restore --staged

[pull]
    rebase = false

[push]
    default = current
